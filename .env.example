# Server Configuration
PORT=8000
HOST=0.0.0.0
ENVIRONMENT=production

# Security — use AGENT_API_KEY for Railway/Render, API_KEY_SECRET as fallback
AGENT_API_KEY=change-me-in-production
API_KEY_SECRET=change-me-in-production
JWT_SECRET=your-secure-jwt-secret-change-this-in-production

# Rate Limiting — 10 req/min as per Day 12 checklist
RATE_LIMIT_MAX=10
RATE_LIMIT_WINDOW=60

# Cost Guard
DAILY_BUDGET_USD=5.0

# Redis (Optional - for scaling)
REDIS_URL=redis://redis:6379/0

# Logging
LOG_LEVEL=INFO